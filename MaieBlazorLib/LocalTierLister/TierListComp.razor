	async Task RearengeTier(string key, int direction)
	{
		if (direction == 0) return;
		await OnLoadingStart.InvokeAsync("Rearenging Tier...");
		List<KeyValuePair<string, Tier>> rearenger = selected.tiers.ToList();
		int index = rearenger.FindIndex((e) => e.Key == key);
		int newindex = index + direction;
		if (newindex < 0 || newindex >= rearenger.Count) return;
		var temp = rearenger[index];
		rearenger.RemoveAt(index);
		rearenger.Insert(newindex, temp);
		selected.tiers = rearenger.ToDictionary();
		await OnLoaded.InvokeAsync("Tier Rearenged!");
	}

	async Task TrySave()
	{
		_saveCts?.Cancel();
		_saveCts = new CancellationTokenSource();
		var token = _saveCts.Token;

		try
		{
			await Task.Delay(500, token);
			if (tl != null)
			{
				await Task.Run(() => tl.SaveAll(), token);
				Logger.LogInformation("Saving!");
			}
			await OnSave.InvokeAsync();
		}
		catch (OperationCanceledException) { /* debounced away, that's fine */ }

	}

