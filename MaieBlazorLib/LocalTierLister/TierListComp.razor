	@if (selectier != null)
	{
		<SingleTierEdit selected="selected" selectier=selectier OnSave="TrySave" OnExit="Exit" OnModified="UpdateModifiedTier" OnLoaded="OnLoaded" OnLoadingStart="OnLoadingStart"></SingleTierEdit>
	}
	
	@if (TierEdit)
	{
		<TierEdit selected="selected" OnSave="TrySave" OnExit="Exit" OnModified="UpdateModifiedTier" OnLoaded="OnLoaded" OnLoadingStart="OnLoadingStart"></TierEdit>
